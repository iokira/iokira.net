---
import BaseLayout from "@layouts/BaseLayout.astro";
import BreadCrumbs from "@components/BreadCrumbs/index.astro";
import { readingTime } from "../utils/readingTime";

const { frontmatter, rawContent } = Astro.props;

const minutes = readingTime(rawContent());

const publishDate = new Date(frontmatter.publishDate).toLocaleDateString(
    "ja-JP",
    { year: "numeric", month: "long", day: "numeric" },
);
const updateDate = frontmatter.updateDate
    ? new Date(frontmatter.updateDate).toLocaleDateString("ja-JP", {
          year: "numeric",
          month: "long",
          day: "numeric",
      })
    : null;
---

<BaseLayout
    pageTitle={frontmatter.title}
    description={frontmatter.description}
>
    <BreadCrumbs
        crumbs={[{ url: "/blog", title: "Weblog" }]}
        topic={frontmatter.title}
    />
    <article class="article">
        <header class="article-header">
            <h1>{frontmatter.title}</h1>
            <div class="article-meta">
                <span>投稿 {publishDate}</span>
                {updateDate && <span>更新 {updateDate}</span>}
                <span>読了目安 {minutes}分</span>
            </div>
        </header>
        <div class="prose">
            <slot />
        </div>
    </article>
</BaseLayout>

<style>
    .article-header {
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
        margin-bottom: 2rem;
    }

    .article-header h1 {
        margin-bottom: 0.75rem;
    }

    .article-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.8rem;
        color: var(--color-text-muted);
        flex-wrap: wrap;
    }

    /* ── Prose styles ── */
    .prose :global(h2) {
        font-size: 1.35rem;
        margin: 2.5rem 0 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--color-border);
    }

    .prose :global(h3) {
        font-size: 1.1rem;
        margin: 2rem 0 0.5rem;
    }

    .prose :global(p) {
        margin-bottom: 1.25rem;
        line-height: 1.8;
    }

    .prose :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .prose :global(a:hover) {
        opacity: 0.8;
    }

    .prose :global(code) {
        font-family:
            "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
        font-size: 0.875em;
        background-color: #f3f4f6;
        padding: 0.15em 0.4em;
        border-radius: 3px;
    }

    .prose :global(pre) {
        position: relative;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5rem 0;
        font-size: 0.875rem;
        line-height: 1.7;
        padding: 1.25rem 1.5rem;
    }

    .prose :global(.copy-button) {
        position: absolute;
        top: 0.6rem;
        right: 0.6rem;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
        font-family: var(--font-sans);
        border: 1px solid rgba(0, 0, 0, 0.15);
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.85);
        color: #555;
        cursor: pointer;
        opacity: 0;
        transition:
            opacity 0.15s,
            background 0.15s;
        line-height: 1.4;
        user-select: none;
    }

    .prose :global(pre:hover .copy-button) {
        opacity: 1;
    }

    .prose :global(.copy-button:hover) {
        background: rgba(255, 255, 255, 1);
    }

    .prose :global(.copy-button.copied) {
        color: #16a34a;
        border-color: rgba(22, 163, 74, 0.35);
    }

    @media (prefers-color-scheme: dark) {
        .prose :global(.copy-button) {
            border-color: rgba(255, 255, 255, 0.15);
            background: rgba(20, 20, 20, 0.8);
            color: #bbb;
        }

        .prose :global(.copy-button:hover) {
            background: rgba(40, 40, 40, 0.95);
        }

        .prose :global(.copy-button.copied) {
            color: #4ade80;
            border-color: rgba(74, 222, 128, 0.35);
        }
    }

    .prose :global(pre code) {
        background: none;
        padding: 0;
        font-size: inherit;
    }

    .prose :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        margin-inline: 0;
        padding: 0.5rem 0 0.5rem 1.25rem;
        color: var(--color-text-muted);
        font-style: italic;
    }

    .prose :global(ul),
    .prose :global(ol) {
        margin-bottom: 1.25rem;
    }

    .prose :global(li) {
        margin-bottom: 0.4rem;
        line-height: 1.7;
    }

    .prose :global(img) {
        border-radius: 6px;
        margin: 1rem 0;
    }

    .prose :global(hr) {
        margin: 2rem 0;
    }

    @media (prefers-color-scheme: dark) {
        .prose :global(code) {
            background-color: #1f2937;
        }
    }
</style>

<script>
    document.querySelectorAll(".prose pre").forEach((pre) => {
        const button = document.createElement("button");
        button.textContent = "コピー";
        button.className = "copy-button";
        button.setAttribute("aria-label", "コードをコピー");

        button.addEventListener("click", async () => {
            const code = pre.querySelector("code")?.textContent ?? "";
            try {
                await navigator.clipboard.writeText(code);
                button.textContent = "✓ コピー";
                button.classList.add("copied");
            } catch {
                button.textContent = "失敗";
            }
            setTimeout(() => {
                button.textContent = "コピー";
                button.classList.remove("copied");
            }, 2000);
        });

        pre.appendChild(button);
    });
</script>
