---
const year = new Date().getFullYear();
---

<footer class="footer">
    <p>&copy; {year} iokira</p>
</footer>

<style>
    .footer {
        border-top: 1px solid var(--color-border);
        padding-block: 1.5rem;
        margin-top: auto;
    }

    .footer p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--color-text-muted);
    }
</style>
