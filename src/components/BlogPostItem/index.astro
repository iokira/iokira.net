---
interface Props {
    post: {
        url: string;
        frontmatter: {
            title: string;
            publishDate: string;
            updateDate?: string;
            description: string;
        };
    };
    readingMinutes: number;
}

const { post, readingMinutes } = Astro.props;

const displayDate = post.frontmatter.updateDate
    ? new Date(post.frontmatter.updateDate).toLocaleDateString("ja-JP", {
          year: "numeric",
          month: "long",
          day: "numeric",
      })
    : new Date(post.frontmatter.publishDate).toLocaleDateString("ja-JP", {
          year: "numeric",
          month: "long",
          day: "numeric",
      });

const isUpdated = !!post.frontmatter.updateDate;
---

<article class="post-item">
    <h3 class="post-title">
        <a href={post.url}>{post.frontmatter.title}</a>
    </h3>
    <div class="post-meta">
        <span class="post-date"
            >{isUpdated ? "更新" : "投稿"} {displayDate}</span
        >
        <span class="post-reading">読了目安 {readingMinutes}分</span>
    </div>
    <p class="post-description">{post.frontmatter.description}</p>
</article>

<style>
    .post-item {
        padding-block: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .post-title {
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0 0 0.4rem;
        line-height: 1.4;
    }

    .post-title a {
        color: var(--color-accent);
        text-decoration: none;
    }

    .post-title a:hover {
        text-decoration: underline;
    }

    .post-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.8rem;
        color: var(--color-text-muted);
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
    }

    .post-description {
        margin: 0;
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.6;
    }
</style>
