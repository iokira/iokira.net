---
interface Props {
    post: {
        url: string;
        frontmatter: {
            title: string;
            publishDate: string;
            description: string;
        };
    };
}

const { post } = Astro.props;
---

<div class="blogPostItem">
    <h3>
        <a href={post.url}>{post.frontmatter.title}</a>
    </h3>
    <p>投稿日: {post.frontmatter.publishDate}</p>
    <p>{post.frontmatter.description}</p>
</div>

<style lang="scss">
    .blogPostItem {
        margin-bottom: 1rem;

        h3 {
            margin: 0 0 0.5rem 0;

            a {
                text-decoration: none;
                color: inherit;

                &:hover {
                    text-decoration: underline;
                }
            }
        }

        p {
            margin: 0.25rem 0;
        }
    }
</style>
